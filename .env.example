# Backend API URL for lead submissions — leave UNSET to use the built-in /api/lead function
# VITE_API_URL=

# ═══ MARKETING PIXELS (Facebook + Instagram = one Meta pixel; TikTok separate) ═══
# Public ids (safe in client). Tracking stays OFF until these are set.
# Meta: business.facebook.com → Events Manager → your Pixel → Pixel ID
VITE_META_PIXEL_ID=
# TikTok: ads.tiktok.com → Assets → Events → Web Events → your Pixel ID
VITE_TIKTOK_PIXEL_ID=

# ═══ PRE-ORDER / PAYMENTS (Stripe) ═══
# Stripe secret key — TEST key (sk_test_...) for now, swap to live (sk_live_...) to take real CHF.
# Get it from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (optional — only for automated confirmation emails).
# From https://dashboard.stripe.com/test/webhooks after adding the /api/stripe-webhook endpoint.
STRIPE_WEBHOOK_SECRET=

# ═══ PRE-ORDER NOTIFICATIONS (pay-on-delivery reservations) — optional ═══
# If set, "pay on delivery" reservations are emailed to you via Resend (https://resend.com).
# Without it, reservations are still captured in the Vercel function logs.
RESEND_API_KEY=
PREORDER_NOTIFY_EMAIL=hallo@krava.ch
PREORDER_FROM_EMAIL=Krava <onboarding@resend.dev>
